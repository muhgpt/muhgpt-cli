# MuhGPT configuration. Copy this file to .env and fill in your key:
#   cp .env.example .env
# The API key is read from the environment only; nothing is hardcoded.

MUHGPT_API_KEY=mghp_your_key_here
MUHGPT_BASE_URL=https://api.muhgpt.com/v1
MUHGPT_MODEL=muh-chat

# --- Optional tuning (defaults shown) -------------------------------------
# MUHGPT_REQUEST_TIMEOUT=60        # per-request read timeout, seconds
# MUHGPT_CONNECT_TIMEOUT=10        # connection timeout, seconds
# MUHGPT_MAX_RETRIES=4             # retries for 429 / 5xx / network errors
# MUHGPT_TEMPERATURE=0.2           # set to "none" to omit (reasoning models)
# MUHGPT_MAX_TOOL_ROUNDS=8         # tool round-trips allowed per turn
# MUHGPT_MAX_HISTORY_MESSAGES=40   # conversation messages kept (0 = unlimited)
# MUHGPT_COMMAND_TIMEOUT=300       # per-command timeout, seconds
# MUHGPT_STREAM=true               # stream replies token-by-token (false to buffer)
# MUHGPT_SHOW_BALANCE=true         # fetch + show your real remaining credits (GET /v1/usage)
#                                  #   at session start. Set false / pass --no-balance to skip.
#                                  #   Use /balance any time; /models lists available models.
# MUHGPT_BIDI=auto                 # RTL (Arabic) display fix: auto | on | off
#                                  #   auto = reshape lines with RTL text so terminals
#                                  #   without BiDi show Arabic correctly. Set "off" if
#                                  #   your terminal already does BiDi (avoids double-reversal).
# MUHGPT_REPORTS_DIR=reports       # where audit logs + reports are written

# --- Autonomous mode (opt-in; default off) --------------------------------
# MUHGPT_AUTO=false                # plan + run read-only recon end-to-end, no per-step [y/N]
# MUHGPT_AUTO_YOLO=false           # high-trust: auto-approve EVERYTHING except the destructive
#                                  #   denylist + secret-file reads (curl/wget/pipes/installs/
#                                  #   file-reads run unattended). Implies --auto. Trusted targets only.
# MUHGPT_SCAN_MODE=standard        # agent depth: quick (fast/breadth) | standard | deep
#                                  #   (exhaustive + vuln chaining). Also --scan-mode.
# MUHGPT_EXTRA_SAFE_RECON=         # comma/space list of EXTRA read-only recon tools to
#                                  #   add to the auto-run allowlist in --auto, e.g.
#                                  #   "gobuster ffuf shodan-cli". Merged with --extra-recon.
#                                  #   Sanitized: shells/interpreters/curl/wget/cat/sudo/… are
#                                  #   rejected (guard._NEVER_RECON), and the denylist +
#                                  #   metacharacter gates still run first, so this can never
#                                  #   auto-run a destructive or chained command. Preview how a
#                                  #   command classifies with:  python main.py --classify "CMD"
# MUHGPT_AUTO_MAX_ROUNDS=40        # model<->tool iterations per objective
# MUHGPT_AUTO_MAX_COMMANDS=60      # auto-approved shell commands per objective
# MUHGPT_AUTO_MAX_INSTALLS=8       # tool installs per objective
# MUHGPT_AUTO_WALLCLOCK_S=1200     # wall-clock cap per objective, seconds
# MUHGPT_AUTO_MAX_BLOCKS=5         # blocked-command attempts before the run aborts
# MUHGPT_AUTO_MAX_IDLE=3           # consecutive unproductive rounds before halting

# --- Optional cost estimate (USD per 1M tokens; shown next to token usage) -
# MUHGPT_PRICE_PROMPT_PER_1M=0
# MUHGPT_PRICE_COMPLETION_PER_1M=0

# --- MCP client (opt-in; default off) -------------------------------------
# Connect to external Model Context Protocol servers and let the model call
# their tools. Tools are namespaced mcp__<server>__<tool> and route through the
# SAME guard as shell commands: in autonomous mode every MCP call defaults to a
# human CONFIRM (never auto-runs), weaponized tools are BLOCKED, and only the
# tools you explicitly list in MUHGPT_MCP_AUTO_TOOLS may auto-run. MuhGPT never
# auto-installs or auto-launches a server — review and pin servers yourself.
# MUHGPT_MCP_ENABLED=false         # master switch (or pass --mcp). When on, a curated
#                                  #   set of FREE no-key servers is loaded automatically
#                                  #   (ddg web search, fetch, wikipedia, sequential-thinking
#                                  #   — needs Node/npx). Your --mcp-config is merged on top.
# MUHGPT_MCP_DEFAULTS=true         # load the bundled free servers (false / --no-mcp-defaults
#                                  #   to use ONLY your own --mcp-config)
# MUHGPT_MCP_CONFIG=mcp.json       # path to an {"mcpServers": {...}} JSON file (added on top)
# MUHGPT_MCP_TIMEOUT=30            # per-call timeout, seconds
# MUHGPT_MCP_AUTO_TOOLS=           # comma/space list of namespaced tools allowed
#                                  #   to auto-run in --auto, e.g.
#                                  #   mcp__shodan__host_info mcp__virustotal__lookup

# --- Research sub-agent (opt-in; OSINT search delegate, relace-search-style) -
# Gives the lead agent a `research` tool (and the /research command) that hands a
# single question to a focused search sub-agent. It runs its own bounded loop over
# the search/fetch/recon tools (best paired with --mcp for web search) and returns
# a concise, SOURCED brief — keeping raw search output out of the main context. The
# sub-agent reuses the SAME guard/approval policy as the lead agent.
# MUHGPT_RESEARCH_ENABLED=false     # master switch (or pass --research). Naming a
#                                   #   research model below also turns it on.
# MUHGPT_RESEARCH_MODEL=            # dedicated model for research (else the main model),
#                                   #   e.g. relace/relace-search or a Perplexity model.
#                                   #   Also --research-model MODEL.
# MUHGPT_RESEARCH_BASE_URL=         # separate provider endpoint for the research model
#                                   #   (else the main base URL), e.g. an OpenRouter URL.
# MUHGPT_RESEARCH_API_KEY=          # API key for that provider (else the main key).
# MUHGPT_RESEARCH_MAX_ROUNDS=12     # sub-agent model<->tool rounds per question
# MUHGPT_RESEARCH_MAX_COMMANDS=20   # sub-agent commands per question
# MUHGPT_RESEARCH_WALLCLOCK_S=300   # wall-clock cap per research question, seconds
