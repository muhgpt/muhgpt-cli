# MuhGPT configuration. Copy this file to .env and fill in your key:
#   cp .env.example .env
# The API key is read from the environment only; nothing is hardcoded.

MUHGPT_API_KEY=mghp_your_key_here
MUHGPT_BASE_URL=https://api.muhgpt.com/v1
MUHGPT_MODEL=muh-chat

# --- Optional tuning (defaults shown) -------------------------------------
# MUHGPT_REQUEST_TIMEOUT=60        # per-request read timeout, seconds
# MUHGPT_CONNECT_TIMEOUT=10        # connection timeout, seconds
# MUHGPT_MAX_RETRIES=4             # retries for 429 / 5xx / network errors
# MUHGPT_TEMPERATURE=0.2           # set to "none" to omit (reasoning models)
# MUHGPT_MAX_TOOL_ROUNDS=8         # tool round-trips allowed per turn
# MUHGPT_MAX_HISTORY_MESSAGES=40   # conversation messages kept (0 = unlimited)
# MUHGPT_COMMAND_TIMEOUT=300       # per-command timeout, seconds
# MUHGPT_STREAM=true               # stream replies token-by-token (false to buffer)
# MUHGPT_REPORTS_DIR=reports       # where audit logs + reports are written

# --- Autonomous mode (opt-in; default off) --------------------------------
# MUHGPT_AUTO=false                # plan + run read-only recon end-to-end, no per-step [y/N]
# MUHGPT_AUTO_MAX_ROUNDS=40        # model<->tool iterations per objective
# MUHGPT_AUTO_MAX_COMMANDS=60      # auto-approved shell commands per objective
# MUHGPT_AUTO_MAX_INSTALLS=8       # tool installs per objective
# MUHGPT_AUTO_WALLCLOCK_S=1200     # wall-clock cap per objective, seconds
# MUHGPT_AUTO_MAX_BLOCKS=5         # blocked-command attempts before the run aborts
# MUHGPT_AUTO_MAX_IDLE=3           # consecutive unproductive rounds before halting

# --- Optional cost estimate (USD per 1M tokens; shown next to token usage) -
# MUHGPT_PRICE_PROMPT_PER_1M=0
# MUHGPT_PRICE_COMPLETION_PER_1M=0
